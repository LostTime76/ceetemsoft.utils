# Numbers
binary: 0b1010_0101
octal: 0o123_456
hexadecimal: 0xdead_1234
integer: -123_234
float: -123.42e123

# Keywords
lit_null: null
lit_true: true
lit_false: false
lit_inf: infinity
lit_ninf: -infinity

# Strings
sl_string: "This is a \b \n \r \\ \t \ \" string. \x12 \uabcd \Udead12"
ml_string: "
	This is a string
	on multiple lines.
	\ Leading space character!
"